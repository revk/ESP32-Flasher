gpio	sd.dat2	2	// DAT2
gpio	sd.dat3	3	// DAT3
gpio	sd.cmd	4	// CMD
gpio	sd.clk	5	// CLK
gpio	sd.dat0	6	// DAT0
gpio	sd.dat1	7	// DAT1
gpio	sd.cd	-8	// CD

gpio	pwr.3	9	// 3.3V power
gpio	pwr.5	10	// 5V power
gpio	led	11	// LED
u8	leds	10 .fix	// How many LEDs

gpio	loop	1	// Loop
gpio	btn	-12	// Button

u8	manifest	.live .hide	// Selected manifest
s	manifesturl	.array=10 .hide	// URL

bit	flash.button	true .live	// Default for "button" (erase) if not in manifest
bit	flash.check	true .live	// Default for "check" if not in manifest
bit	flash.erase	false .live	// Default for (always) "erase" if not in manifest
u8	flash.verify	1 .live	// Default for "verify" if not in manifest
